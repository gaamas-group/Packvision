# ------------------------------------------------------------------
#  Packvision Backend Environment Variables
# ------------------------------------------------------------------
#
#  This file serves as a template for the required environment variables.
#  Copy this file to a new file named `.env` in the same directory (`/backend`)
#  and replace the placeholder values with your actual configuration.
#
#  DO NOT commit the `.env` file to version control.
#
# ------------------------------------------------------------------

# -- Application Settings --
# -----------------------------
# Port for the backend server to listen on.
# Default: 4000
PORT=4000

# -- Database Configuration (PostgreSQL) --
# ----------------------------------------
# Connection string for your PostgreSQL database.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://packvision_user:your_secure_password@localhost:5432/packvision_db"

# -- Security & Authentication --
# ---------------------------------
# A strong, unique secret key for signing JWTs.
# Generate a secure key using a tool like `openssl rand -hex 32`.
JWT_SECRET="your_super_secret_jwt_key_that_is_at_least_32_characters_long"

# JWT token expiration time.
# Examples: "1h", "24h", "7d"
# Default: "24h"
JWT_EXPIRES_IN="24h"

# -- AWS S3 Configuration --
# --------------------------
# For S3-compatible storage like AWS S3 or MinIO.
#
# Your AWS Access Key ID.
AWS_ACCESS_KEY_ID="your_aws_access_key_id"
#
# Your AWS Secret Access Key.
AWS_SECRET_ACCESS_KEY="your_aws_secret_access_key"
#
# The AWS region where your S3 bucket is located.
# Example: "us-east-1", "eu-west-2"
AWS_REGION="us-east-1"
#
# The name of the S3 bucket to use for storing recordings.
AWS_S3_BUCKET_NAME="your-packvision-recordings-bucket"
